---
layout: default
---

<link rel="stylesheet" href="{{ '/assets/css/publication-graph.css' | relative_url }}">

<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
  </header>

  <!-- View toggle -->
  <div class="mb-4" id="view-toggle">
    <button class="btn btn-sm btn-primary mr-2" id="btn-graph" onclick="showView('graph')">
      Graph View
    </button>
    <button class="btn btn-sm btn-outline-primary" id="btn-list" onclick="showView('list')">
      List View
    </button>
  </div>

  <!-- Graph View (default) -->
  <div id="graph-view">
    <div id="publication-graph" style="width:100%; height:600px; border:none; border-radius:0.75rem;">
      <p class="text-muted p-3">Graph loading...</p>
    </div>
    <div class="d-flex flex-wrap align-items-center mt-2" style="gap:1rem;">
      <span class="text-muted small">
        <svg width="12" height="12" style="vertical-align:middle;margin-right:4px;"><circle cx="6" cy="6" r="6" fill="#818cf8"/></svg>
        Research topics
      </span>
      <span class="text-muted small">
        <svg width="12" height="12" style="vertical-align:middle;margin-right:4px;"><circle cx="6" cy="6" r="6" fill="#22c55e"/></svg>
        Published papers
      </span>
      <span class="text-muted small">
        <svg width="12" height="12" style="vertical-align:middle;margin-right:4px;"><circle cx="6" cy="6" r="6" fill="#eab308"/></svg>
        Under review
      </span>
      <span class="text-muted small">
        <svg width="12" height="12" style="vertical-align:middle;margin-right:4px;"><circle cx="6" cy="6" r="6" fill="#94a3b8"/></svg>
        In preparation
      </span>
      <span class="text-muted small ml-auto">Drag to rearrange &middot; hover for details &middot; click topic to jump to list</span>
    </div>
  </div>

  <!-- List View (hidden by default) -->
  <div id="list-view" style="display:none;">
    {% assign project_nodes = site.data.graph.nodes | where: "type", "project" %}
    {% for proj_node in project_nodes %}
      {% assign proj_page = site.projects | where: "slug", proj_node.id | first %}
      <div class="mb-5" id="{{ proj_node.id }}">
        <h3>
          {{ proj_node.label }}
          {% if proj_node.years %}
            <small class="text-muted ml-2">{{ proj_node.years }}</small>
          {% endif %}
        </h3>
        {% if proj_page and proj_page.description %}
          <p class="text-muted">{{ proj_page.description }}</p>
        {% endif %}

        {% assign paper_ids = "" | split: "" %}
        {% for edge in site.data.graph.edges %}
          {% if edge.source == proj_node.id %}
            {% assign paper_ids = paper_ids | push: edge.target %}
          {% endif %}
        {% endfor %}

        {% if paper_ids.size > 0 %}
        <ul>
          {% for node in site.data.graph.nodes %}
            {% if node.type == "paper" and paper_ids contains node.id %}
            <li class="{% if node.status == 'under-review' or node.status == 'in-preparation' %}text-muted{% endif %} mb-1">
              {% if node.url and node.url != "" %}
                <a href="{{ node.url }}" target="_blank">{{ node.label }}</a>
              {% else %}
                {{ node.label }}
              {% endif %}
              ({{ node.year }})
              {% if node.venue and node.venue != "" %} &mdash; <em>{{ node.venue }}</em>{% endif %}
              {% if node.status == "under-review" %}
                <span class="badge badge-warning ml-1">Under review</span>
              {% elsif node.status == "in-preparation" %}
                <span class="badge badge-secondary ml-1">In preparation</span>
              {% endif %}
            </li>
            {% endif %}
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    {% endfor %}

    <!-- Orphan papers (no project edge) -->
    {% assign all_edge_targets = site.data.graph.edges | map: "target" %}
    {% assign orphan_papers = "" | split: "" %}
    {% for node in site.data.graph.nodes %}
      {% if node.type == "paper" %}
        {% unless all_edge_targets contains node.id %}
          {% assign orphan_papers = orphan_papers | push: node %}
        {% endunless %}
      {% endif %}
    {% endfor %}
    {% if orphan_papers.size > 0 %}
    <div class="mb-5" id="other">
      <h3>Other Publications</h3>
      <ul>
        {% for node in orphan_papers %}
        <li class="mb-1">
          {% if node.url and node.url != "" %}
            <a href="{{ node.url }}" target="_blank">{{ node.label }}</a>
          {% else %}
            {{ node.label }}
          {% endif %}
          ({{ node.year }})
          {% if node.venue and node.venue != "" %} &mdash; <em>{{ node.venue }}</em>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>

  <!-- Inject graph data for D3 (Task 6) -->
  <script>
  window.graphData = {{ site.data.graph | jsonify }};
  </script>

  <!-- D3 and graph script (added in Task 6) -->
  <script src="https://cdn.jsdelivr.net/npm/d3@7" defer></script>
  <script src="{{ '/assets/js/publication-graph.js' | relative_url }}" defer></script>

  <script>
  function showView(view) {
    document.getElementById('graph-view').style.display = view === 'graph' ? 'block' : 'none';
    document.getElementById('list-view').style.display  = view === 'list'  ? 'block' : 'none';
    document.getElementById('btn-graph').className = view === 'graph'
      ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-outline-primary';
    document.getElementById('btn-list').className = view === 'list'
      ? 'btn btn-sm btn-primary' : 'btn btn-sm btn-outline-primary';
  }
  </script>
</div>
